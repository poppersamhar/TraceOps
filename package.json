{
  "name": "traceops",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:web",
    "dev:server": "tsx watch apps/worker/src/index.ts",
    "dev:web": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "test": "tsx --test apps/worker/src/store.test.ts",
    "preview": "vite preview --host 0.0.0.0",
    "start": "tsx apps/worker/src/index.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "npm-run-all": "^4.1.5",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.6.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.7"
  }
}
