{
  "name": "traceops",
  "version": "0.1.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel dev:server:v0.1 dev:web:v0.1",
    "dev:v0.1": "npm run dev",
    "dev:v0.2": "npm-run-all --parallel dev:server:v0.2 dev:web:v0.2",
    "dev:server": "npm run dev:server:v0.1",
    "dev:server:v0.1": "cross-env TRACEOPS_PRODUCT_MODE=0.1.0 tsx watch apps/worker/src/index.ts",
    "dev:server:v0.2": "cross-env TRACEOPS_PRODUCT_MODE=0.2.0 tsx watch apps/worker/src/index.ts",
    "dev:web": "npm run dev:web:v0.1",
    "dev:web:v0.1": "vite --host 0.0.0.0 --config vite.config.ts",
    "dev:web:v0.2": "vite --host 0.0.0.0 --config vite.v0.2.config.ts",
    "typecheck": "tsc",
    "build": "npm-run-all typecheck build:v0.1 build:v0.2",
    "build:v0.1": "vite build --config vite.config.ts",
    "build:v0.2": "vite build --config vite.v0.2.config.ts",
    "test": "tsx --test apps/worker/src/store.test.ts apps/worker/src/modules/spaceCollectorV01.test.ts",
    "preview": "vite preview --host 0.0.0.0 --config vite.config.ts",
    "preview:v0.1": "npm run preview",
    "preview:v0.2": "vite preview --host 0.0.0.0 --config vite.v0.2.config.ts",
    "collector": "npm-run-all build:v0.1 collector:start",
    "collector:start": "cross-env TRACEOPS_PRODUCT_MODE=0.1.0 TRACEOPS_SERVE_COLLECTOR=true tsx apps/worker/src/index.ts",
    "start": "npm run collector:start",
    "start:v0.2": "cross-env TRACEOPS_PRODUCT_MODE=0.2.0 tsx apps/worker/src/index.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "npm-run-all": "^4.1.5",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.6.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.7"
  }
}
